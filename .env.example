# Yandex Cloud credentials
YC_CLOUD_ID=b1gXXXXXXXXXX
YC_FOLDER_ID=b1gXXXXXXXXXX
YC_TOKEN=AQAAAA...
YC_SERVICE_ACCOUNT_ID=ajeXXXXXXXXXX

# Project settings
PROJECT_NAME=mlops
YC_ZONE=ru-central1-a

# Cluster settings
K8S_VERSION=1.31
NODE_CORES=2
NODE_MEMORY=4
NODE_COUNT=3

# S3 bucket settings (suffix будет добавлен автоматически)
BUCKET_PREFIX=mlops

# S3 credentials (from Yandex Cloud service account)
AWS_ACCESS_KEY_ID=YCAJE...
AWS_SECRET_ACCESS_KEY=YCP...

# После создания кластера будут доступны:
# BUCKET_NAME - полное имя бакета
# CLUSTER_ID - ID кластера
# CLUSTER_NAME - имя кластера